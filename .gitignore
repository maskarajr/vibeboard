# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# cursor / local agent state
.cursor

# local notes & secrets (never commit)
.residuals/
*.pem
*.key
*.p12
*.pfx

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example as the only committed template
.env
.env.*
!.env.example

# vercel / render local
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
